<?xml version="1.0"?>
<robot name="my_arm">
  <link name="base_link">
    <visual>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
    </visual>
    <collision>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.3"/>
      <inertia ixx="0.0008125" ixy="0" ixz="0" iyy="0.0008125" iyz="0" izz="0.0015"/>
    </inertial>
  </link>

  <link name="arm_0">
    <visual>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry><cylinder radius="0.03" length="0.3"/></geometry>
      <material name="blue">
      <color rgba="0 0 1 1"/>
    </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry><cylinder radius="0.03" length="0.3"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <mass value="0.6"/>
      <inertia ixx="0.004635" ixy="0" ixz="0" iyy="0.004635" iyz="0" izz="0.00027"/>
    </inertial>
  </link>

  <link name="arm_1">
    <visual>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry><cylinder radius="0.03" length="0.3"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry><cylinder radius="0.03" length="0.3"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <mass value="0.6"/>
      <inertia ixx="0.004635" ixy="0" ixz="0" iyy="0.004635" iyz="0" izz="0.00027"/>
    </inertial>
  </link>

  <link name="arm_2">
    <visual>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry><cylinder radius="0.03" length="0.3"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry><cylinder radius="0.03" length="0.3"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <mass value="0.6"/>
      <inertia ixx="0.004635" ixy="0" ixz="0" iyy="0.004635" iyz="0" izz="0.00027"/>
    </inertial>
  </link>

  <joint name="arm_0_joint" type="revolute">
    <parent link="base_link"/>
    <child link="arm_0"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="1"/>
  </joint>

  <joint name="arm_1_joint" type="revolute">
    <parent link="arm_0"/>
    <child link="arm_1"/>
    <origin xyz="0 0 0.3" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1"/>
  </joint>

  <joint name="arm_2_joint" type="revolute">
    <parent link="arm_1"/>
    <child link="arm_2"/>
    <origin xyz="0 0 0.3" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1"/>
  </joint>

  <link name="gripper_base">
    <visual>
      <geometry><box size="0.05 0.1 0.02"/></geometry>
    </visual>
    <visual>
      <geometry><box size="0.05 0.1 0.02"/></geometry>
    </visual>
    <collision>
      <geometry><box size="0.05 0.1 0.02"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.0000867" ixy="0" ixz="0" iyy="0.0000242" iyz="0" izz="0.0001042"/>
    </inertial>
  </link>

  <joint name="gripper_base_joint" type="fixed">
    <parent link="arm_2"/>
    <child link="gripper_base"/>
    <origin xyz="0 0 0.3" rpy="0 0 0"/>
  </joint>

  <link name="gripper_1">
    <visual>
      <geometry><box size="0.02 0.02 0.05"/></geometry>
    </visual>
    <collision>
      <geometry><box size="0.02 0.02 0.05"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.02"/>
      <inertia ixx="0.00000483" ixy="0" ixz="0" iyy="0.00000483" iyz="0" izz="0.00000133"/>
    </inertial>
  </link>

  <joint name="gripper_1_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child link="gripper_1"/>
    <origin xyz="0 0.03 0.025" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="0.05" effort="10" velocity="0.1"/>
  </joint>

  <link name="gripper_2">
    <visual>
      <geometry><box size="0.02 0.02 0.05"/></geometry>
    </visual>
    <collision>
      <geometry><box size="0.02 0.02 0.05"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.02"/>
      <inertia ixx="0.00000483" ixy="0" ixz="0" iyy="0.00000483" iyz="0" izz="0.00000133"/>
    </inertial>
  </link>

  <joint name="gripper_2_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child link="gripper_2"/>
    <origin xyz="0 -0.03 0.025" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="0" upper="0.05" effort="10" velocity="0.1"/>
  </joint>

  <ros2_control name="GazeboSystem" type="system">
  <hardware>
    <plugin>gz_ros2_control/GazeboSimSystem</plugin>
  </hardware>
  <joint name="arm_0_joint">
    <command_interface name="position"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>
  <joint name="arm_1_joint">
    <command_interface name="position"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>
  <joint name="arm_2_joint">
    <command_interface name="position"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>
  <joint name="gripper_1_joint">
    <command_interface name="position"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>
  <joint name="gripper_2_joint">
    <command_interface name="position"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="libgz_ros2_control-system.so"
          name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find arm_moveit_config)/config/ros2_controllers.yaml</parameters>
      <controller_manager_name>controller_manager</controller_manager_name>
    </plugin>
  </gazebo>

</robot>

