<?xml version="1.0"?>
<launch>
  <let name="urdf_file" value="$(find-pkg-share my_robot_description)/urdf/arm.urdf" />
  <node pkg="robot_state_publisher" exec="robot_state_publisher">
    <param name="robot_description" value="$(file-content $(var urdf_file))" type="str" />
  </node>
  <node pkg="rviz2" exec="rviz2" />
  <node pkg="my_robot_motion" exec="my_first_node" />
</launch>
